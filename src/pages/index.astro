---
// Redirect to the user's preferred language
// Runs on the client since Astro static export can't read Accept-Language
---
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content="0; url=/en/" />
  <script>
    // Prefer Korean if browser language is Korean, otherwise English
    const lang = (navigator.language || navigator.languages?.[0] || 'en').toLowerCase();
    const target = lang.startsWith('ko') ? '/ko/' : '/en/';
    if (window.location.pathname === '/') {
      window.location.replace(target);
    }
  </script>
</head>
<body></body>
</html>
